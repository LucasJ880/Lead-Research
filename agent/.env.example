# BidToGo Local MERX Agent — Configuration
# Copy to .env and fill in your values

# Cloud API connection
CLOUD_API_URL=https://bidtogo.ca
AGENT_API_KEY=your-agent-api-key-here

# MERX credentials (never share or commit)
MERX_EMAIL=your-merx-email@example.com
MERX_PASSWORD=your-merx-password

# Optional: OpenAI key for local document analysis
OPENAI_API_KEY=
