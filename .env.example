# ══════════════════════════════════════════════════════════
# BidToGo — Environment Variables (canonical contract)
# Copy to .env and fill in real values
# ══════════════════════════════════════════════════════════

# ---------- Database ----------
POSTGRES_DB=leadharvest
POSTGRES_USER=leadharvest
POSTGRES_PASSWORD=changeme_in_production
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
DATABASE_URL=postgresql://leadharvest:changeme_in_production@localhost:5433/leadharvest?schema=public

# ---------- Redis ----------
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_URL=redis://localhost:6380/0

# ---------- Next.js / Auth ----------
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-me-run-openssl-rand-base64-32

# ---------- Admin Seed User ----------
ADMIN_EMAIL=admin@yourcompany.com
ADMIN_PASSWORD=change-this-password

# ---------- Scraper Service ----------
# MUST be the same value for both web app and scraper service
SCRAPER_API_URL=http://localhost:8001
SCRAPER_API_KEY=scraper-internal-key-change-in-prod

# ---------- Crawl Settings ----------
DEFAULT_RATE_LIMIT_SECONDS=3
DEFAULT_MAX_PAGES_PER_SOURCE=20
DEFAULT_USER_AGENT=LeadHarvest/1.0
RESPECT_ROBOTS_TXT=true

# ---------- MERX Credentials ----------
MERX_EMAIL=
MERX_PASSWORD=

# ---------- OpenAI ----------
OPENAI_API_KEY=

# ---------- Logging ----------
LOG_LEVEL=info
