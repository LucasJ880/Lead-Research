# ===========================================
# LeadHarvest — Environment Configuration
# ===========================================
# Copy this file to .env and fill in the values.
# NEVER commit the .env file to version control.

# ---------- Database ----------
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=leadharvest
POSTGRES_USER=leadharvest
POSTGRES_PASSWORD=changeme_in_production
DATABASE_URL=postgresql://leadharvest:changeme_in_production@localhost:5433/leadharvest?schema=public

# ---------- Redis ----------
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_URL=redis://localhost:6380/0

# ---------- Next.js ----------
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-me-run-openssl-rand-base64-32

# ---------- Admin Seed User ----------
ADMIN_EMAIL=admin@leadharvest.local
ADMIN_PASSWORD=changeme

# ---------- Python Scraper Service ----------
SCRAPER_API_URL=http://localhost:8001
SCRAPER_API_KEY=scraper-internal-key-change-in-prod

# ---------- Crawl Settings ----------
DEFAULT_RATE_LIMIT_SECONDS=3
DEFAULT_MAX_PAGES_PER_SOURCE=20
DEFAULT_USER_AGENT=LeadHarvest/1.0 (+https://leadharvest.local/bot; bot@leadharvest.local)
RESPECT_ROBOTS_TXT=true

# ---------- Export ----------
MAX_EXPORT_ROWS=10000

# ---------- Logging ----------
LOG_LEVEL=info
